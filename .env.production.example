TZ=America/Sao_Paulo

# Imagens publicadas pelo workflow no GitHub Container Registry.
BACKEND_IMAGE=ghcr.io/sidneyjunio-nerus/assinatura-nerus/backend:latest
FRONTEND_IMAGE=ghcr.io/sidneyjunio-nerus/assinatura-nerus/frontend:latest
BACKEND_PORT=3001
FRONTEND_PORT=3000

DB_USER=root
DB_PASS=123456
DB_NAME=assinaturas

# URL publica que o navegador vai usar para chamar a API.
# No frontend, esse valor entra no build da imagem. Configure tambem
# NEXT_PUBLIC_API_URL em Settings > Secrets and variables > Actions > Variables.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Dados SFTP usados pelo backend para enviar/remover imagens.
SFTP_HOST=sftp.exemplo.com
SFTP_PORT=22
SFTP_USER=usuario_sftp
SFTP_PASS=senha_sftp
SFTP_BASE_URL=https://assinaturas.nerus.com.br
SFTP_REMOTE_DIR=/

# URL publica usada no frontend para fundo.png, logo.jpeg e logo2.png.
# Configure tambem NEXT_PUBLIC_SFTP_BASE_URL nas Variables do repositorio.
NEXT_PUBLIC_SFTP_BASE_URL=https://assinaturas.nerus.com.br
